# Copy this file to ".env" and fill in your values.
# ".env" is git-ignored and must NOT be included in the submission ZIP.

# PostgreSQL connection string (SQLAlchemy/psycopg2 format).
# Example (Neon):
#   postgresql+psycopg2://USER:PASSWORD@HOST/neondb?sslmode=require
POSTGRES_URL=

# Google Sheet id: the long string between /d/ and /edit in the sheet URL.
GOOGLE_SHEET_ID=

# Optional: override path to the service-account JSON.
# GOOGLE_CREDENTIALS_PATH=google-sheets-api.json
